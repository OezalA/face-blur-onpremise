<Window x:Class="FaceBlurApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Face Blur — On-Premise" Height="600" Width="800">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Video preview area -->
        <Image x:Name="PreviewImage" Grid.Row="0" Stretch="Uniform" />

        <!-- FPS / ms overlay on top of the preview -->
        <TextBlock x:Name="FpsText" Grid.Row="0" Text=""
                   Foreground="#00FF00" FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" />

        <!-- Control bar at the bottom -->
        <Border Grid.Row="1" Background="#2D2D30" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="StartButton" Content="Start Camera" Width="120"
                        Click="StartButton_Click" />
                <Button x:Name="StopButton" Content="Stop" Width="80" Margin="10,0,0,0"
                        Click="StopButton_Click" IsEnabled="False" />

                <CheckBox x:Name="DetectionToggle" Content="Detection" IsChecked="True"
                          Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"
                          Checked="DetectionToggle_Changed" Unchecked="DetectionToggle_Changed" />

                <TextBlock Text="Blur" Foreground="White" VerticalAlignment="Center" Margin="20,0,6,0" />
                <Slider x:Name="BlurSlider" Width="140" Minimum="5" Maximum="40" Value="13"
                        VerticalAlignment="Center" IsDirectionReversed="True"
                        ValueChanged="BlurSlider_ValueChanged"
                        ToolTip="Right = stronger (fewer mosaic blocks)" />

                <TextBlock x:Name="StatusText" Text="Ready" Foreground="White"
                           VerticalAlignment="Center" Margin="20,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
